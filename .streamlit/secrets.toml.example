# Streamlit Community Cloud secrets template
# -------------------------------------------
# On Streamlit Cloud: paste the contents of this file into
# App Settings → Secrets (TOML format), filling in real values.
#
# For local development, use .env instead — do NOT create a real
# secrets.toml locally as it would conflict with .env loading.

# ── AI Insight Layer (optional) ───────────────────────────────────────────────
# Provide at least one key to enable AI-generated executive summaries.
# Leave both empty to use built-in template mode (no API key required).
ANTHROPIC_API_KEY = ""
OPENAI_API_KEY = ""

# ── Application overrides (optional) ─────────────────────────────────────────
# Uncomment and set only the values you want to change from defaults.

# CHURN_WINDOW_DAYS = 90
# LOG_LEVEL = "INFO"
# MAX_UPLOAD_SIZE_MB = 50
